{
  "欠薪": {
    "required": [
      "身份证明",
      "劳动合同或用工证明",
      "工资约定证明",
      "考勤记录或工作记录",
      "工资流水或欠薪记录"
    ],
    "optional": [
      "聊天记录",
      "工友证言",
      "工作照片"
    ],
    "advice": [
      "优先固定工资标准和拖欠区间",
      "如果没有书面合同，可用考勤、工牌、聊天记录补强劳动关系"
    ]
  },
  "工伤": {
    "required": [
      "身份证明",
      "劳动合同或用工证明",
      "事故经过说明",
      "医院诊断材料",
      "工伤认定材料"
    ],
    "optional": [
      "现场照片",
      "工友证言",
      "医疗费票据"
    ],
    "advice": [
      "先确认是否完成工伤认定，未认定前赔偿主张通常不完整",
      "注意保留事故时间、地点、施工项目和就医记录"
    ]
  },
  "未签劳动合同": {
    "required": [
      "身份证明",
      "入职时间证明",
      "实际工作证明",
      "工资支付记录",
      "未签合同情况说明"
    ],
    "optional": [
      "工牌照片",
      "招聘记录",
      "聊天记录"
    ],
    "advice": [
      "重点证明入职时间和持续用工事实",
      "如主张双倍工资，需要明确未签合同持续期间"
    ]
  }
}
